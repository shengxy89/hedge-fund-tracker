# =============================================================================
# Database — choose one of the two presets below.
# =============================================================================

# Local dev (default): SQLite file in project root
DATABASE_URL=sqlite:///./hedge_fund_db.sqlite

# Production: PostgreSQL via docker-compose
# DATABASE_URL=postgresql+psycopg2://hedge:hedge123@localhost:5432/hedge_fund_db

# =============================================================================
# SEC API
# =============================================================================
# Required by SEC EDGAR. Replace with your real name + email — SEC will block
# requests without a valid User-Agent.
SEC_USER_AGENT=YourName your@email.com
SEC_API_BASE=https://data.sec.gov

# Optional commercial primary source (default pipeline skips it; see ETL_SKIP_FORMS13F)
FORMS13F_API_BASE=https://api.forms13f.com/v1

# =============================================================================
# Optional: Commercial APIs
# =============================================================================
FMP_API_KEY=
WHALEWISDOM_API_KEY=

# =============================================================================
# App
# =============================================================================
LOG_LEVEL=INFO
MAX_RETRIES=3
RATE_LIMIT_DELAY=0.15
